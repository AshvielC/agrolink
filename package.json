{
  "name": "agrolink-marketplace",
  "version": "1.0.0",
  "description": "A secure Node.js, Express, MongoDB starter app connecting farmers and buyers.",
  "main": "src/server.js",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "build": "node src/scripts/buildAssets.js",
    "check": "node -e \"const fs=require('fs'),path=require('path'),cp=require('child_process');function walk(d){for(const f of fs.readdirSync(d)){const p=path.join(d,f),s=fs.statSync(p);if(s.isDirectory())walk(p);else if(p.endsWith('.js'))cp.execFileSync(process.execPath,['--check',p],{stdio:'inherit'});}}walk('src');walk('public/js');\"",
    "audit:prod": "npm audit --omit=dev",
    "create-admin": "node src/scripts/createAdmin.js",
    "security:audit": "npm audit --omit=dev",
    "security:check": "npm run check && npm run security:audit",
    "prepack:clean": "node src/scripts/cleanPackage.js",
    "db:indexes:user-identities": "node src/scripts/applyUserIdentityIndexes.js",
    "test": "node --test --test-concurrency=1",
    "ci": "npm run verify && npm run security:audit",
    "db:indexes:notifications": "node src/scripts/applyNotificationIndexes.js",
    "notifications:process-once": "node src/scripts/processNotificationOutboxOnce.js",
    "monitor:local": "powershell.exe -ExecutionPolicy Bypass -File ./src/scripts/check-local-health.ps1",
    "monitor:health:local": "node --use-system-ca src/scripts/checkLocalHealth.js",
    "backup:local": "powershell.exe -ExecutionPolicy Bypass -File ./scripts/backup-agrolink-local.ps1",
    "restore:test": "powershell.exe -ExecutionPolicy Bypass -File ./scripts/restore-test-agrolink-local.ps1",
    "verify": "npm run build && npm run check && npm test"
  },
  "keywords": [
    "nodejs",
    "express",
    "mongodb",
    "mongoose",
    "marketplace",
    "farmers",
    "buyers"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "connect-mongo": "^5.1.0",
    "cookie-parser": "^1.4.6",
    "dotenv": "^16.4.7",
    "ejs": "^3.1.10",
    "express": "^5.2.1",
    "express-ejs-layouts": "^2.5.1",
    "express-rate-limit": "^7.5.0",
    "express-session": "^1.18.1",
    "express-validator": "^7.2.1",
    "git": "^0.1.5",
    "helmet": "^8.0.0",
    "mongoose": "^9.6.1",
    "morgan": "^1.10.0",
    "multer": "^2.0.2",
    "nodemailer": "^9.0.1",
    "pdfkit": "^0.15.2",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "javascript-obfuscator": "^4.1.1",
    "nodemon": "^3.1.14"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "allowScripts": {
    "sharp@0.34.5": true
  }
}
