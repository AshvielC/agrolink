# AgroLink environment template
# Copy this file to .env and replace placeholder values.
# Never commit your real .env file.

NODE_ENV=development
PORT=3443
APP_NAME=AgroLink
APP_URL=https://localhost:3443

# Database
MONGODB_URI=mongodb+srv://YOUR_DB_USERNAME:YOUR_URL_ENCODED_DB_PASSWORD@YOUR_CLUSTER.mongodb.net/agrolink?retryWrites=true&w=majority

# Sessions and cookies
# Generate each secret with:
# node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=generate-a-random-48-byte-hex-secret
COOKIE_SECRET=generate-a-different-random-48-byte-hex-secret
TRUST_PROXY_HOPS=0

# Logging: debug, info, warn, or error
LOG_LEVEL=info

# SMTP for password reset
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@example.com
SMTP_PASS=your-email-app-password
EMAIL_FROM="AgroLink <no-reply@example.com>"

# Admin bootstrap, used by npm run create-admin
ADMIN_NAME=AgroLink Admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace-with-a-strong-admin-password

# Authentication security
MAX_FAILED_LOGIN_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15
PASSWORD_RESET_WINDOW_MINUTES=15
PASSWORD_RESET_MAX_REQUESTS=5
PASSWORD_RESET_ACCOUNT_MAX_REQUESTS=3
ADMIN_REAUTH_MINUTES=15

# Upload security
UPLOAD_VIRUS_SCAN_REQUIRED=false
CLAMSCAN_PATH=clamscan
UPLOAD_VIRUS_SCAN_TIMEOUT_MS=120000
UPLOAD_VIRUS_SCAN_STARTUP_TIMEOUT_MS=180000
UPLOAD_VIRUS_SCAN_MAX_CONCURRENT=2
UPLOAD_VIRUS_SCAN_MAX_QUEUED=10

# PDF security
REJECT_ENCRYPTED_UPLOADS=true
PDF_SECURITY_CHECK_REQUIRED=false
QPDF_PATH=qpdf
PDF_SECURITY_CHECK_TIMEOUT_MS=15000

# Notification outbox
NOTIFICATION_OUTBOX_ENABLED=true
NOTIFICATION_OUTBOX_POLL_INTERVAL_MS=5000
NOTIFICATION_OUTBOX_BATCH_SIZE=25
NOTIFICATION_OUTBOX_LOCK_STALE_MS=300000
NOTIFICATION_OUTBOX_BASE_RETRY_DELAY_MS=30000
NOTIFICATION_OUTBOX_MAX_RETRY_DELAY_MS=1800000

# Operational monitoring
MONITOR_BASE_URL=http://127.0.0.1:3000
MONITOR_HEALTH_TIMEOUT_MS=10000
MONITOR_HTTP_5XX_WINDOW_MINUTES=5
MONITOR_HTTP_5XX_MAX_ERRORS=5
MONITOR_ACCOUNT_LOCKOUT_WINDOW_MINUTES=15
MONITOR_ACCOUNT_LOCKOUT_MAX_EVENTS=5
MONITOR_ALERT_COOLDOWN_MINUTES=15
MONITOR_STORAGE_CHECK_INTERVAL_MINUTES=10
MONITOR_STORAGE_WARNING_MB=1024
MONITOR_STORAGE_GROWTH_WARNING_MB=100

# Backup and restore-test settings
BACKUP_ROOT=backups
BACKUP_RETENTION_COUNT=10
RESTORE_TEST_MONGODB_URI=mongodb+srv://YOUR_USERNAME:YOUR_PASSWORD@YOUR_CLUSTER.mongodb.net/agrolink_restore_test?retryWrites=true&w=majority

# Optional local HTTPS only. Production HTTPS should be terminated by the deployment platform or reverse proxy.
HTTPS_ENABLED=true
HTTPS_PFX_PATH=certs/agrolink-local.pfx
HTTPS_PFX_PASSPHRASE=

# Demo mode
DEMO_MODE=false
DEMO_NOTICE=Demo Mode: This platform is currently being tested. Please use test information only.
