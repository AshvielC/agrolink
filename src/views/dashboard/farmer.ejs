<section class="dashboard-section">
  <div class="container">
    <div class="dashboard-hero">
      <div>
        <p class="eyebrow">Farmer dashboard</p>
        <h1>Hello, <%= currentUser.name %>.</h1>
        <p>Manage your produce, buyer enquiries, and farm profile from one place.</p>
      </div>
      <div class="hero-action-stack">
        <% if (productCount >= maxProductsPerFarmer) { %>
          <span class="btn btn-disabled" aria-disabled="true">Product limit reached</span>
        <% } else { %>
          <a class="btn btn-primary" href="/dashboard/farmer/products/new">Add produce</a>
        <% } %>
        <a class="btn btn-secondary" href="/dashboard/farmer/orders">Buyer requests</a>
        <a class="btn btn-secondary" href="/dashboard/farmer/orders/history">Order history</a>
        <a class="btn btn-secondary" href="/dashboard/farmer/profile">My profile</a>
      </div>
    </div>

    <div class="metric-grid">
      <% metrics.forEach((metric) => { %>
        <article class="metric-card">
          <span><%= metric.label %></span>
          <strong><%= metric.value %></strong>
        </article>
      <% }) %>
    </div>

    <div class="section-heading row-heading">
      <div>
        <p class="eyebrow">Recent listings</p>
        <h2>Your produce listings</h2>
      </div>
      <a class="btn btn-secondary" href="/dashboard/farmer/products">Manage all</a>
    </div>

    <% if (!recentProducts.length) { %>
      <div class="empty-state compact-empty">
        <span class="empty-icon">🌾</span>
        <h2>No produce listed yet.</h2>
        <p class="muted-text">Create your first produce listing so buyers can discover what you have available.</p>
        <a class="btn btn-primary" href="/dashboard/farmer/products/new">Create listing</a>
      </div>
    <% } else { %>
      <div class="product-grid compact-product-grid">
        <% recentProducts.forEach((product) => { %>
          <article class="product-card">
            <%- include('../partials/product-image', { product }) %>
            <div class="product-card-top">
              <span class="product-category"><%= product.category %></span>
              <span class="status-pill status-<%= product.status %>"><%= formatStatus(product.status) %></span>
            </div>
            <h2><%= product.name %></h2>
            <dl class="product-meta">
              <div>
                <dt>Quantity</dt>
                <dd><%= product.quantity %> <%= product.unit %></dd>
              </div>
              <div>
                <dt>Price</dt>
                <dd><%= formatMoney(product.price, product.currency) %> / <%= product.unit %><br><small><%= vatModeLabel(product.vatMode || 'none') %><% if (product.vatRate) { %> · <%= product.vatRate %>% VAT<% } %></small></dd>
              </div>
            </dl>
            <div class="product-actions compact-actions">
              <a class="btn btn-secondary" href="/dashboard/farmer/products/<%= product._id %>/edit">Edit</a>
              <% if (product.status === 'available') { %>
                <form action="/dashboard/farmer/products/<%= product._id %>/status" method="POST" data-confirm="Mark this product as not available? Buyers will no longer see it in the active marketplace.">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                  <input type="hidden" name="status" value="unavailable">
                  <button class="btn btn-secondary" type="submit">Not available</button>
                </form>
              <% } else { %>
                <form action="/dashboard/farmer/products/<%= product._id %>/status" method="POST">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                  <input type="hidden" name="status" value="available">
                  <button class="btn btn-primary" type="submit">Available</button>
                </form>
              <% } %>
            </div>
          </article>
        <% }) %>
      </div>
    <% } %>

    <div class="section-heading row-heading">
      <div>
        <p class="eyebrow">Recent buyer requests</p>
        <h2>Incoming activity</h2>
      </div>
      <div class="card-action-stack"><a class="btn btn-secondary" href="/dashboard/farmer/orders">View active</a><a class="btn btn-secondary" href="/dashboard/farmer/orders/history">View history</a></div>
    </div>

    <% if (!recentRequests.length) { %>
      <div class="empty-state compact-empty">
        <span class="empty-icon">📩</span>
        <h2>No buyer requests yet.</h2>
        <p class="muted-text">Requests will appear here once buyers start requesting your produce.</p>
      </div>
    <% } else { %>
      <div class="mini-list">
        <% recentRequests.forEach((request) => { %>
          <article class="mini-row">
            <div>
              <span class="status-pill status-<%= request.status %>"><%= formatStatus(request.status) %></span>
              <h3><%= request.productSnapshot?.name || 'Produce request' %></h3>
              <p class="muted-text"><%= request.buyerSnapshot?.name || 'Buyer' %> requested <%= request.requestedQuantity %> <%= request.unit %> on <%= formatDate(request.createdAt) %>.</p>
            </div>
          </article>
        <% }) %>
      </div>
    <% } %>
  </div>
</section>
