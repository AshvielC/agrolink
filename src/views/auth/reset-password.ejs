<section class="auth-section">
  <div class="container narrow-container">
    <div class="auth-card">
      <p class="eyebrow">Reset password</p>
      <h1>Create a new password</h1>

      <%- include('../partials/form-errors', { errors }) %>

      <% if (linkValid) { %>
        <p class="muted-text">
          Enter your new password. After it is updated, you will be logged in automatically.
        </p>

        <form class="stacked-form" action="/reset-password/<%= token %>" method="POST" novalidate>
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">

          <div class="form-field">
            <label for="password">New password</label>
            <div class="password-wrap">
              <input id="password" name="password" type="password" autocomplete="new-password" minlength="8" required>
              <button class="password-toggle" type="button" data-password-toggle aria-label="Show password">Show</button>
            </div>
          </div>

          <div class="form-field">
            <label for="confirmPassword">Confirm new password</label>
            <div class="password-wrap">
              <input id="confirmPassword" name="confirmPassword" type="password" autocomplete="new-password" minlength="8" required>
              <button class="password-toggle" type="button" data-password-toggle aria-label="Show password">Show</button>
            </div>
          </div>

          <button class="btn btn-primary btn-full" type="submit">Update password and log in</button>
        </form>
      <% } %>

      <p class="auth-switch">
        <a href="/forgot-password">Request a new reset link</a>
      </p>
    </div>
  </div>
</section>
