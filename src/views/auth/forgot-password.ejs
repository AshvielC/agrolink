<section class="auth-section">
  <div class="container narrow-container">
    <div class="auth-card">
      <p class="eyebrow">Account recovery</p>
      <h1>Forgot password?</h1>
      <p class="muted-text">
        Enter your registered email address. If the account exists, we will send a password reset link valid for 15 minutes.
      </p>

      <%- include('../partials/form-errors', { errors }) %>

      <form class="stacked-form" action="/forgot-password" method="POST" novalidate>
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">

        <div class="form-field">
          <label for="email">Registered email address</label>
          <input id="email" name="email" type="email" value="<%= formData.email || '' %>" autocomplete="email" maxlength="254" required>
        </div>

        <button class="btn btn-primary btn-full" type="submit">Send reset link</button>
      </form>

      <p class="auth-switch">Remembered your password? <a href="/login">Log in</a>.</p>
    </div>
  </div>
</section>
