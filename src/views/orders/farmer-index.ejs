<section class="dashboard-section">
  <div class="container">
    <div class="dashboard-hero">
      <div>
        <p class="eyebrow"><%= isHistory ? 'Order history' : 'Buyer requests' %></p>
        <h1><%= isHistory ? 'Review closed buyer requests.' : 'Manage incoming requests.' %></h1>
        <p><%= isHistory ? 'Completed, rejected, and cancelled requests are kept here for your records and printing.' : 'Accept suitable requests, reject unavailable requests, cancel accepted requests when needed, and issue receipts after successful payment, and confirm pickup/delivery.' %></p>
      </div>
      <div class="card-action-stack">
        <a class="btn btn-secondary" href="/dashboard/farmer/products">Manage produce</a>
        <% if (isHistory) { %>
          <a class="btn btn-primary" href="/dashboard/farmer/orders">Active requests</a>
        <% } else { %>
          <a class="btn btn-secondary" href="/dashboard/farmer/orders/history">View history</a>
        <% } %>
        <% if (orders.length) { %>
          <button class="btn btn-secondary" type="button" data-print>Print this page</button>
        <% } %>
      </div>
    </div>

    <form class="filter-card order-filter-card" action="<%= isHistory ? '/dashboard/farmer/orders/history' : '/dashboard/farmer/orders' %>" method="GET">
      <label for="q">Search
        <input id="q" name="q" type="search" maxlength="100" value="<%= filters?.q || '' %>" placeholder="Product, buyer, phone, location...">
      </label>
      <label for="status">Request status
        <select id="status" name="status">
          <option value="">All statuses</option>
          <% statuses.forEach((status) => { %>
            <option value="<%= status %>" <%= selectedStatus === status ? 'selected' : '' %>><%= formatStatus(status) %></option>
          <% }) %>
        </select>
      </label>
      <label for="paymentStatus">Payment
        <select id="paymentStatus" name="paymentStatus">
          <option value="">All payments</option>
          <option value="unpaid" <%= filters?.paymentStatus === 'unpaid' ? 'selected' : '' %>>Unpaid</option>
          <option value="paid" <%= filters?.paymentStatus === 'paid' ? 'selected' : '' %>>Paid</option>
        </select>
      </label>
      <label for="fulfillmentStatus">Pickup/delivery
        <select id="fulfillmentStatus" name="fulfillmentStatus">
          <option value="">All schedules</option>
          <% ['not_scheduled','requested','reschedule_requested','confirmed','completed','cancelled'].forEach((status) => { %>
            <option value="<%= status %>" <%= filters?.fulfillmentStatus === status ? 'selected' : '' %>><%= formatStatus(status) %></option>
          <% }) %>
        </select>
      </label>
      <div class="filter-actions">
        <button class="btn btn-primary" type="submit">Search</button>
        <a class="btn btn-secondary" href="<%= isHistory ? '/dashboard/farmer/orders/history' : '/dashboard/farmer/orders' %>">Reset</a>
      </div>
    </form>

    <% if (!orders.length) { %>
      <div class="empty-state">
        <span class="empty-icon">📩</span>
        <h2><%= isHistory ? 'No order history found.' : 'No active buyer requests found.' %></h2>
        <p class="muted-text"><%= isHistory ? 'Closed buyer requests will appear here after they are completed, rejected, or cancelled.' : 'New buyer requests will appear here once buyers start requesting your produce.' %></p>
      </div>
    <% } else { %>
      <div class="order-list">
        <% orders.forEach((order) => { %>
          <article class="order-card">
            <div class="order-card-main">
              <% if (order.productSnapshot?.imagePath) { %>
                <img class="order-thumb" src="<%= order.productSnapshot.imagePath %>" alt="Photo of <%= order.productSnapshot.name || 'product' %>">
              <% } else { %>
                <div class="order-thumb order-thumb-placeholder" aria-hidden="true">🌿</div>
              <% } %>
              <div>
                <div class="product-card-top order-card-topline">
                  <span class="product-category"><%= order.productSnapshot?.category || 'Produce' %></span>
                  <span class="status-pill status-<%= order.status %>"><%= formatStatus(order.status) %></span>
                </div>
                <h2><%= order.productSnapshot?.name || order.product?.name || 'Produce request' %></h2>
                <p class="muted-text"><%= order.buyerSnapshot?.name || order.buyer?.name || 'Buyer' %> requested <strong><%= order.requestedQuantity %> <%= order.unit %></strong>.</p>
<% if (order.buyer?._id) { %>
                  <a class="subtle-link" href="/dashboard/farmer/buyers/<%= order.buyer._id %>/profile">View buyer profile</a>
                <% } %>
              </div>
            </div>

            <dl class="product-meta order-meta">
              <div>
                <dt>Price at request</dt>
                <dd><%= formatMoney(order.productSnapshot?.price, order.productSnapshot?.currency || 'FJD') %> / <%= order.unit %><br><small><%= orderVatSummary(order) %></small></dd>
              </div>
              <div>
                <dt>Total price</dt>
                <dd><strong><%= formatMoney(orderTotalPrice(order), order.productSnapshot?.currency || 'FJD') %></strong></dd>
              </div>
              <div>
                <dt>VAT</dt>
                <dd><%= orderVatSummary(order) %> · <%= formatMoney(orderVatAmount(order), order.productSnapshot?.currency || 'FJD') %></dd>
              </div>
              <div>
                <dt>Product location</dt>
                <dd><%= order.productSnapshot?.location || 'Not set' %></dd>
              </div>
              <div>
                <dt>Requested on</dt>
                <dd><%= formatDate(order.createdAt) %></dd>
              </div>
              <% if (!isHistory && order.status === 'pending') { %>
                <div>
                  <dt>Current available stock</dt>
                  <dd><%= order.product ? `${order.product.quantity} ${order.product.unit || order.unit}` : 'Product removed' %></dd>
                </div>
              <% } %>
              <% if (order.inventoryDeducted) { %>
                <div>
                  <dt>Inventory</dt>
                  <dd>Reserved from stock</dd>
                </div>
              <% } %>
              <% if (order.inventoryRestoredAt) { %>
                <div>
                  <dt>Inventory restored</dt>
                  <dd><%= formatDateTime(order.inventoryRestoredAt) %></dd>
                </div>
              <% } %>
              <div>
                <dt>Payment</dt>
                <dd><%= order.paymentStatus === 'paid' ? `Paid by ${paymentMethodLabel(order.paymentMethod)}` : 'Not paid yet' %></dd>
              </div>
              <% if (order.receiptIssuedAt) { %>
                <div>
                  <dt>Receipt issued</dt>
                  <dd><%= formatDateTime(order.receiptIssuedAt) %></dd>
                </div>
              <% } %>
              <div>
                <dt>Buyer contact</dt>
                <dd><%= order.buyerContactEmail %></dd>
              </div>
              <% if (order.cancelledByRole) { %>
                <div>
                  <dt>Cancelled by</dt>
                  <dd><%= formatStatus(order.cancelledByRole) %></dd>
                </div>
              <% } %>
            </dl>

            <% if (order.buyerContactPhone) { %>
              <p class="muted-text"><strong>Phone:</strong> <%= order.buyerContactPhone %></p>
            <% } %>

            <% if (order.status === 'accepted' || order.fulfillment?.status && order.fulfillment.status !== 'not_scheduled') { %>
              <%- include('_schedule-panel', { order, viewerRole: 'farmer' }) %>
            <% } %>

            <% if (order.deliveryNote) { %>
              <div class="note-box">
                <strong>Pickup/delivery note</strong>
                <p><%= order.deliveryNote %></p>
              </div>
            <% } %>

            <% if (order.message) { %>
              <div class="note-box">
                <strong>Buyer message</strong>
                <p><%= order.message %></p>
              </div>
            <% } %>

            <% if (order.farmerResponse) { %>
              <div class="note-box farmer-response-box">
                <strong>Your response</strong>
                <p><%= order.farmerResponse %></p>
              </div>
            <% } %>

            <% if (order.history && order.history.length) { %>
              <details class="history-panel">
                <summary>View activity history</summary>
                <ol class="history-list">
                  <% order.history.forEach((event) => { %>
                    <li>
                      <strong><%= event.action %></strong>
                      <span><%= formatStatus(event.actorRole) %> · <%= formatDateTime(event.createdAt) %></span>
                      <% if (event.note) { %>
                        <p><%= event.note %></p>
                      <% } %>
                    </li>
                  <% }) %>
                </ol>
              </details>
            <% } %>

            <div class="product-actions order-actions">
              <% if (order.receiptIssuedAt) { %>
                <a class="btn btn-secondary" href="/dashboard/farmer/orders/<%= order._id %>/receipt"><%= order.receiptStatus === 'cancelled' ? 'View cancelled receipt' : 'View receipt' %></a>
              <% } else { %>
                <span class="btn btn-disabled" aria-disabled="true">Receipt not issued</span>
              <% } %>
              <a class="btn btn-secondary" href="/dashboard/farmer/orders/<%= order._id %>">View order</a>
              <a class="btn btn-secondary" href="/dashboard/farmer/orders/<%= order._id %>/print">Download order PDF</a>

              <% if (order.buyer?._id) { %>
                <a class="btn btn-secondary" href="/dashboard/messages/compose/<%= order.buyer._id %>?orderId=<%= order._id %>">Message buyer</a>
                <a class="btn btn-secondary" href="/dashboard/farmer/buyers/<%= order.buyer._id %>/profile">Buyer profile</a>
                <a class="btn btn-secondary" href="/dashboard/reports/new?targetType=order&targetId=<%= order._id %>">Report order issue</a>
              <% } %>
            </div>

            <% if (!isHistory && (order.status === 'pending' || order.status === 'accepted')) { %>
              <form class="order-status-form" action="/dashboard/farmer/orders/<%= order._id %>/status" method="POST">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <label for="farmerResponse-<%= order._id %>">
                  Response note, optional
                  <textarea id="farmerResponse-<%= order._id %>" name="farmerResponse" rows="3" maxlength="500" placeholder="Example: Accepted. Please collect from my farm gate on Saturday morning."><%= order.farmerResponse || '' %></textarea>
                </label>
                <div class="product-actions order-actions">
                  <% if (order.status === 'pending') { %>
                    <% const canAccept = order.product && order.product.status === 'available' && Number(order.product.quantity) >= Number(order.requestedQuantity); %>
                    <% if (canAccept) { %>
                      <button class="btn btn-primary" type="submit" name="status" value="accepted">Accept</button>
                    <% } else { %>
                      <span class="btn btn-disabled" aria-disabled="true">Not enough stock</span>
                    <% } %>
                    <button class="btn btn-danger" type="submit" name="status" value="rejected" data-confirm-submit="Reject this request? The buyer will be notified.">Reject</button>
                  <% } %>
                  <% if (order.status === 'accepted') { %>
                    <span class="btn btn-disabled" aria-disabled="true">Record payment and complete pickup/delivery below</span>
                    <button class="btn btn-danger" type="submit" name="status" value="cancelled" data-confirm-submit="Cancel this accepted order request? The buyer will be notified.">Cancel order</button>
                  <% } %>
                </div>
              </form>
            <% } %>

            <% if (order.status === 'accepted' && !order.receiptIssuedAt) { %>
              <%- include('_receipt-issue-form', { order }) %>
            <% } %>

            <% if (isHistory && order.status === 'completed' && !order.receiptIssuedAt) { %>
              <%- include('_receipt-issue-form', { order }) %>
            <% } %>
          </article>
        <% }) %>
      </div>
    <% } %>
  </div>
</section>
